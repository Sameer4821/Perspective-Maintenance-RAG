# ============================================================
# Prescriptive Maintenance RAG Agent — Environment Variables
# ============================================================
# CRITICAL RULES:
#   1. NEVER commit this file to Git
#   2. NEVER share this file with anyone
#   3. NEVER print these values in logs
#   4. This file is already in .gitignore (safe)
# ============================================================

# ------------------------------------------------------------
# LLAMA CLOUD API KEY
# ------------------------------------------------------------
# Used by: parser/parser.py → LlamaParse cloud PDF parser
# Get yours free at: https://cloud.llamaindex.ai
# Free tier: 1,000 pages/day — more than enough for this project
# Format: llx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLAMA_CLOUD_API_KEY=llx-mnC3h9rWeW55vShsa9I4uqmtAfACPkOdMWj1aDPoIsgcgbdJ

# ------------------------------------------------------------
# EMBEDDING MODEL SETTINGS
# ------------------------------------------------------------
# The HuggingFace model used to convert text into vectors.
# BAAI/bge-small-en-v1.5 is:
#   - Free (no API key needed)
#   - Runs locally on your CPU
#   - 384-dimensional vectors
#   - Best-in-class for its size on MTEB benchmark
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ------------------------------------------------------------
# CHROMADB SETTINGS
# ------------------------------------------------------------
# Where ChromaDB stores its data on your disk.
# This folder is in .gitignore — large binary files stay local.
# Relative path from the project root.
CHROMA_PERSIST_DIRECTORY=./chroma_storage

# The name of our ChromaDB collection.
# Think of a collection like a "table" in a regular database.
# All our manual chunks will be stored under this name.
CHROMA_COLLECTION_NAME=maintenance_manuals

# ------------------------------------------------------------
# CHUNKING SETTINGS
# ------------------------------------------------------------
# Maximum number of characters per chunk.
# 1000 chars ≈ 200-250 words ≈ a good paragraph from a manual.
# Too small → loses context. Too large → retrieval is imprecise.
CHUNK_SIZE=1000

# Number of characters overlapping between consecutive chunks.
# Prevents important information from being split across chunk boundaries.
# Example: If a sentence starts at end of chunk 3, it also appears in chunk 4.
CHUNK_OVERLAP=200

# ------------------------------------------------------------
# PARSER SETTINGS
# ------------------------------------------------------------
# LlamaParse output format.
# "markdown" preserves tables as | col | col | and headings as ## Section
# This is the best format for downstream chunking and retrieval.
PARSE_RESULT_TYPE=markdown

# Maximum number of pages to parse per document.
# Set to 0 for unlimited. During development, limit to save API credits.
MAX_PAGES_PER_DOC=50

# ------------------------------------------------------------
# LOGGING SETTINGS
# ------------------------------------------------------------
# Controls how much detail appears in the console.
# Options: DEBUG (everything) | INFO (normal) | WARNING | ERROR
# Use INFO during development, WARNING in production.
LOG_LEVEL=INFO

# ------------------------------------------------------------
# PROJECT PATHS
# ------------------------------------------------------------
# Where raw PDF manuals are stored (input)
MANUALS_DIR=./data/manuals

# Where LlamaParse output is saved (structured markdown)
PARSED_DIR=./data/parsed

# Where chunked text is saved (ready for embedding)
CHUNKS_DIR=./data/chunks
